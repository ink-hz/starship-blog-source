---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const allPosts = await getCollection('blog');
const sortedPosts = allPosts
  .filter(post => !post.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

// 收集所有 tag 并按出现次数排序
const tagCount: Record<string, number> = {};
sortedPosts.forEach(post => {
  post.data.tags?.forEach(tag => {
    tagCount[tag] = (tagCount[tag] || 0) + 1;
  });
});
const allTags = Object.entries(tagCount).sort((a, b) => b[1] - a[1]).map(([tag]) => tag);
---

<BaseLayout title="博客文章" description="所有技术博客文章">
  <h1>📚 所有文章</h1>

  <div class="tag-filter">
    <button class="tag-btn active" data-tag="all">全部 ({sortedPosts.length})</button>
    {allTags.map(tag => (
      <button class="tag-btn" data-tag={tag}>
        {tag} ({tagCount[tag]})
      </button>
    ))}
  </div>

  <ul class="post-list" id="post-list">
    {sortedPosts.map((post) => (
      <li class="post-item" data-tags={post.data.tags?.join(',') ?? ''}>
        <a href={`/blog/${post.slug}/`}>
          <h2>{post.data.title}</h2>
          <p class="description">{post.data.description}</p>
          <div class="meta">
            <time>{post.data.pubDate.toLocaleDateString('zh-CN')}</time>
            {post.data.tags && (
              <div class="tags">
                {post.data.tags.map((tag) => <span class="tag">#{tag}</span>)}
              </div>
            )}
          </div>
        </a>
      </li>
    ))}
  </ul>
</BaseLayout>

<script>
  const buttons = document.querySelectorAll<HTMLButtonElement>('.tag-btn');
  const items = document.querySelectorAll<HTMLLIElement>('.post-item');

  buttons.forEach(btn => {
    btn.addEventListener('click', () => {
      buttons.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');

      const tag = btn.dataset.tag!;
      items.forEach(item => {
        if (tag === 'all' || item.dataset.tags?.split(',').includes(tag)) {
          item.style.display = '';
        } else {
          item.style.display = 'none';
        }
      });
    });
  });
</script>

<style>
  h1 {
    margin-bottom: 1.5rem;
    color: var(--text);
    font-weight: 700;
  }

  .tag-filter {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 2.5rem;
  }

  .tag-btn {
    padding: 0.3rem 0.8rem;
    border: 1px solid var(--border);
    border-radius: 20px;
    background: var(--surface);
    color: var(--gray);
    font-size: 0.875rem;
    cursor: pointer;
    transition: all 0.3s;
  }

  .tag-btn:hover {
    border-color: var(--accent);
    color: var(--accent);
    box-shadow: var(--glow);
  }

  .tag-btn.active {
    background: transparent;
    border-color: var(--accent);
    color: var(--accent);
    box-shadow: var(--glow);
    text-shadow: var(--glow);
  }

  .post-list {
    list-style: none;
  }

  .post-item {
    margin-bottom: 2rem;
    padding: 1.5rem;
    border: 1px solid var(--border);
    border-radius: 8px;
    background: var(--surface);
    transition: all 0.3s;
  }

  .post-item:last-child {
    border-bottom: 1px solid var(--border);
  }

  .post-item:hover {
    border-color: var(--accent);
    box-shadow: var(--glow);
  }

  .post-item a {
    text-decoration: none;
    color: inherit;
    display: block;
  }

  .post-item h2 {
    font-size: 1.5rem;
    margin-bottom: 0.5rem;
    color: var(--text);
    transition: color 0.3s;
    font-weight: 600;
  }

  .post-item a:hover h2 {
    color: var(--accent);
  }

  .description {
    color: var(--gray);
    margin-bottom: 1rem;
    font-size: 1rem;
    line-height: 1.6;
  }

  .meta {
    display: flex;
    align-items: center;
    gap: 1rem;
    font-size: 0.9rem;
    color: var(--gray);
  }

  .tags {
    display: flex;
    gap: 0.5rem;
  }

  .tag {
    color: var(--accent);
    background: var(--code-bg);
    padding: 0.2rem 0.5rem;
    border-radius: 4px;
  }
</style>
