---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const allPosts = await getCollection('blog');
const sortedPosts = allPosts
  .filter(post => !post.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const recentPosts = sortedPosts.slice(0, 5);
---

<BaseLayout
  title="AI 架构实践 - 大规模 AI 应用的架构设计"
  description="专注于大规模 AI 应用的架构设计、工程实践和性能优化"
>
  <section class="hero">
    <div class="blackhole-bg"></div>
    <h1>大规模 AI 应用的架构设计与工程实践</h1>
    <p class="lead">
      从 LLM 应用开发、分布式训练、推理优化，到云原生部署与成本优化，
      分享真实的生产环境经验和架构最佳实践。
    </p>
  </section>

  <section class="recent-posts">
    <h2>📝 最新文章</h2>
    <ul class="post-list">
      {recentPosts.map((post) => (
        <li class="post-item">
          <a href={`/blog/${post.slug}/`}>
            <h3>{post.data.title}</h3>
            <p class="description">{post.data.description}</p>
            <time>{post.data.pubDate.toLocaleDateString('zh-CN')}</time>
          </a>
        </li>
      ))}
    </ul>
    <a href="/blog" class="view-all">查看所有文章 →</a>
  </section>
</BaseLayout>

<style>
  .hero {
    position: relative;
    margin: 2rem 0 4rem 0;
    padding: 4rem 0;
    border-bottom: 1px solid var(--border);
    overflow: hidden;
  }

  .blackhole-bg {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 400px;
    height: 400px;
    background: radial-gradient(
      circle at center,
      #000 0%,
      #000 25%,
      #06b6d4 40%,
      #3b82f6 55%,
      #8b5cf6 70%,
      transparent 100%
    );
    opacity: 0.15;
    animation: blackholeRotate 20s linear infinite;
    pointer-events: none;
    z-index: 0;
  }

  @keyframes blackholeRotate {
    from { transform: translate(-50%, -50%) rotate(0deg); }
    to { transform: translate(-50%, -50%) rotate(360deg); }
  }

  .hero h1, .hero .lead {
    position: relative;
    z-index: 1;
  }

  .hero h1 {
    font-size: 2.5rem;
    margin-bottom: 1.5rem;
    line-height: 1.2;
    font-weight: 700;
    background: linear-gradient(135deg, #06b6d4 0%, #3b82f6 50%, #8b5cf6 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .lead {
    font-size: 1.1rem;
    color: var(--gray);
    margin-bottom: 2rem;
    line-height: 1.7;
  }

  .cta {
    display: flex;
    gap: 1rem;
  }

  .btn-primary, .btn-secondary {
    padding: 0.8rem 1.5rem;
    border-radius: 8px;
    text-decoration: none;
    font-weight: 600;
    transition: all 0.3s;
  }

  .btn-primary {
    background: transparent;
    color: var(--accent);
    border: 2px solid var(--accent);
  }

  .btn-primary:hover {
    background: rgba(0, 240, 255, 0.1);
    transform: translateY(-2px);
    box-shadow: var(--glow), 0 0 20px rgba(0, 240, 255, 0.2);
  }

  .btn-secondary {
    background: transparent;
    color: var(--text);
    border: 2px solid var(--border);
  }

  .btn-secondary:hover {
    background: var(--surface);
    border-color: var(--accent);
    box-shadow: var(--glow);
  }

  .recent-posts {
    margin-top: 4rem;
  }

  .recent-posts h2 {
    margin-bottom: 2rem;
  }

  .post-list {
    list-style: none;
  }

  .post-item {
    margin-bottom: 2rem;
    padding: 1.5rem;
    border: 1px solid var(--border);
    border-radius: 8px;
    background: var(--surface);
    transition: all 0.3s;
  }

  .post-item:last-child {
    border-bottom: 1px solid var(--border);
  }

  .post-item:hover {
    border-color: var(--accent);
    box-shadow: var(--glow);
  }

  .post-item a {
    text-decoration: none;
    color: inherit;
    display: block;
  }

  .post-item h3 {
    font-size: 1.25rem;
    margin-bottom: 0.5rem;
    color: var(--text);
    transition: color 0.3s;
    font-weight: 600;
  }

  .post-item a:hover h3 {
    color: var(--accent);
  }

  .description {
    color: var(--gray);
    margin-bottom: 0.5rem;
  }

  .post-item time {
    font-size: 0.9rem;
    color: var(--gray);
  }

  .view-all {
    display: inline-block;
    margin-top: 1rem;
    color: var(--accent);
    text-decoration: none;
    font-weight: 600;
    transition: all 0.3s;
  }

  .view-all:hover {
    color: var(--accent-hover);
    text-shadow: var(--glow);
  }
</style>
