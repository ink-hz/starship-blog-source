---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const allPosts = await getCollection('blog');
const sortedPosts = allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const recentPosts = sortedPosts.slice(0, 5);
---

<BaseLayout
  title="AI 架构实践 - 大规模 AI 应用的架构设计"
  description="专注于大规模 AI 应用的架构设计、工程实践和性能优化"
>
  <section class="hero">
    <h1>大规模 AI 应用的架构设计与工程实践</h1>
    <p class="lead">
      从 LLM 应用开发、分布式训练、推理优化，到云原生部署与成本优化，
      分享真实的生产环境经验和架构最佳实践。
    </p>
  </section>

  <section class="recent-posts">
    <h2>📝 最新文章</h2>
    <ul class="post-list">
      {recentPosts.map((post) => (
        <li class="post-item">
          <a href={`/blog/${post.slug}/`}>
            <h3>{post.data.title}</h3>
            <p class="description">{post.data.description}</p>
            <time>{post.data.pubDate.toLocaleDateString('zh-CN')}</time>
          </a>
        </li>
      ))}
    </ul>
    <a href="/blog" class="view-all">查看所有文章 →</a>
  </section>
</BaseLayout>

<style>
  .hero {
    margin: 2rem 0 4rem 0;
    padding-bottom: 3rem;
    border-bottom: 1px solid var(--border);
  }

  .hero h1 {
    font-size: 2.5rem;
    margin-bottom: 1.5rem;
    line-height: 1.2;
    color: var(--text);
    font-weight: 700;
  }

  .lead {
    font-size: 1.1rem;
    color: var(--gray);
    margin-bottom: 2rem;
    line-height: 1.7;
  }

  .cta {
    display: flex;
    gap: 1rem;
  }

  .btn-primary, .btn-secondary {
    padding: 0.8rem 1.5rem;
    border-radius: 8px;
    text-decoration: none;
    font-weight: 600;
    transition: all 0.3s;
  }

  .btn-primary {
    background: var(--accent);
    color: #ffffff;
  }

  .btn-primary:hover {
    background: var(--accent-hover);
    transform: translateY(-2px);
    box-shadow: 0 8px 16px rgba(37, 99, 235, 0.3);
  }

  .btn-secondary {
    background: transparent;
    color: var(--text);
    border: 2px solid var(--border);
  }

  .btn-secondary:hover {
    background: var(--code-bg);
    border-color: var(--accent);
  }

  .recent-posts {
    margin-top: 4rem;
  }

  .recent-posts h2 {
    margin-bottom: 2rem;
  }

  .post-list {
    list-style: none;
  }

  .post-item {
    margin-bottom: 2rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--border);
  }

  .post-item:last-child {
    border-bottom: none;
  }

  .post-item a {
    text-decoration: none;
    color: inherit;
    display: block;
  }

  .post-item h3 {
    font-size: 1.25rem;
    margin-bottom: 0.5rem;
    color: var(--text);
    transition: color 0.3s;
    font-weight: 600;
  }

  .post-item a:hover h3 {
    color: var(--accent);
  }

  .description {
    color: var(--gray);
    margin-bottom: 0.5rem;
  }

  .post-item time {
    font-size: 0.9rem;
    color: var(--gray);
  }

  .view-all {
    display: inline-block;
    margin-top: 1rem;
    color: var(--accent);
    text-decoration: none;
    font-weight: 600;
    transition: color 0.2s;
  }

  .view-all:hover {
    color: var(--accent-hover);
    text-decoration: underline;
  }
</style>
