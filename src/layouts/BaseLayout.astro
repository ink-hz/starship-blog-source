---
interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <style>
      :root {
        --bg: #000000;
        --text: #e2e8f0;
        --accent: #06b6d4;
        --accent-hover: #3b82f6;
        --gray: #94a3b8;
        --border: #2a3a4e;
        --code-bg: #1a2332;
        --glow: 0 0 10px rgba(6, 182, 212, 0.3);
        --surface: #1a2332;
      }

      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      html {
        overflow-x: hidden;
      }

      body {
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif;
        background: var(--bg);
        color: var(--text);
        line-height: 1.6;
        font-size: 16px;
        min-height: 100vh;
        position: relative;
        overflow-x: hidden;
      }

      body::before {
        content: '';
        position: fixed;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        width: 100vw;
        height: 100vh;
        background: radial-gradient(circle at center,
                    rgba(6,182,212,0.4) 0%,
                    rgba(59,130,246,0.3) 20%,
                    rgba(139,92,246,0.25) 40%,
                    transparent 70%);
        z-index: 0;
        pointer-events: none;
        animation: blackholePulse 8s ease-in-out infinite;
      }

      @keyframes blackholePulse {
        0%, 100% {
          transform: translate(-50%, -50%) scale(1);
          opacity: 0.8;
        }
        50% {
          transform: translate(-50%, -50%) scale(1.1);
          opacity: 1;
        }
      }

      body > * {
        position: relative;
        z-index: 1;
      }

      main {
        max-width: 1000px;
        margin: 0 auto;
        padding: 2rem 2rem;
      }

      header {
        border-bottom: 1px solid var(--border);
        padding-bottom: 1rem;
        margin-bottom: 3rem;
      }

      nav {
        display: flex;
        gap: 2rem;
      }

      nav a {
        color: var(--accent);
        text-decoration: none;
        margin-right: 1.5rem;
        font-weight: 500;
        transition: all 0.3s;
      }

      nav a:hover {
        color: var(--accent-hover);
        text-shadow: var(--glow);
      }

      footer {
        border-top: 1px solid var(--border);
        margin-top: 4rem;
        padding-top: 1.5rem;
        color: var(--gray);
        font-size: 0.875rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
      }

      footer a {
        color: var(--accent);
        text-decoration: none;
      }

      footer a:hover {
        text-shadow: var(--glow);
      }
    </style>
  </head>
  <body>
    <main>
      <header>
        <nav>
          <a href="/">首页</a>
          <a href="/blog">博客</a>
          <a href="https://github.com/ink-hz" target="_blank">GitHub</a>
        </nav>
      </header>
      <slot />
      <footer>
        <span>© 2026 ink-hz · AI & 云原生技术</span>
        <span>
          <a href="mailto:ink_hz@163.com">ink_hz@163.com</a>
          &nbsp;·&nbsp;
          <a href="https://github.com/ink-hz" target="_blank">GitHub</a>
        </span>
      </footer>
    </main>

    <!-- Mermaid.js 客户端渲染 -->
    <script type="module">
      import mermaid from 'https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.esm.min.mjs';

      // 初始化 Mermaid - 使用 default 主题以支持内联 style
      mermaid.initialize({
        startOnLoad: false,
        theme: 'dark',
        flowchart: {
          useMaxWidth: false,
          htmlLabels: true,
          curve: 'basis'
        },
        securityLevel: 'loose'
      });

      // 等待 DOM 加载完成
      window.addEventListener('DOMContentLoaded', () => {
        console.log('开始查找 Mermaid 代码块...');

        // 查找所有可能包含 mermaid 的代码块
        const codeBlocks = document.querySelectorAll('pre code');
        console.log('找到代码块数量:', codeBlocks.length);

        let mermaidCount = 0;
        codeBlocks.forEach((block, index) => {
          // 检查是否是 mermaid 代码块（通过 class 或内容）
          const isMermaid = block.className.includes('mermaid') ||
                           block.className.includes('language-mermaid') ||
                           block.textContent.trim().startsWith('graph') ||
                           block.textContent.trim().startsWith('sequenceDiagram') ||
                           block.textContent.trim().startsWith('classDiagram') ||
                           block.textContent.trim().startsWith('flowchart');

          if (isMermaid) {
            mermaidCount++;
            console.log(`找到 Mermaid 代码块 #${mermaidCount}:`, block.className);

            // 获取 Mermaid 代码
            const code = block.textContent;

            // 创建一个新的 div 元素来渲染图表
            const mermaidDiv = document.createElement('div');
            mermaidDiv.className = 'mermaid';
            mermaidDiv.textContent = code;
            // 创建外层滚动容器
            const wrapper = document.createElement('div');
            wrapper.style.overflowX = 'auto';
            wrapper.style.margin = '20px 0';
            wrapper.style.borderRadius = '8px';
            wrapper.style.cursor = 'grab';
            wrapper.style.maxWidth = '100%';
            wrapper.style.WebkitOverflowScrolling = 'touch';

            mermaidDiv.style.backgroundColor = '#1a2332';
            mermaidDiv.style.padding = '20px';
            mermaidDiv.style.borderRadius = '8px';
            mermaidDiv.style.minWidth = '1200px';
            mermaidDiv.style.width = 'max-content';

            wrapper.appendChild(mermaidDiv);

            // 添加鼠标拖拽功能（绑定到wrapper）
            let isDragging = false;
            let startX, scrollLeft;

            wrapper.addEventListener('mousedown', (e) => {
              isDragging = true;
              wrapper.style.cursor = 'grabbing';
              startX = e.pageX - wrapper.offsetLeft;
              scrollLeft = wrapper.scrollLeft;
            });

            wrapper.addEventListener('mouseleave', () => {
              isDragging = false;
              wrapper.style.cursor = 'grab';
            });

            wrapper.addEventListener('mouseup', () => {
              isDragging = false;
              wrapper.style.cursor = 'grab';
            });

            wrapper.addEventListener('mousemove', (e) => {
              if (!isDragging) return;
              e.preventDefault();
              const x = e.pageX - wrapper.offsetLeft;
              const walk = (x - startX) * 2;
              wrapper.scrollLeft = scrollLeft - walk;
            });

            // 触摸拖拽支持（移动端）
            let touchStartX;
            wrapper.addEventListener('touchstart', (e) => {
              touchStartX = e.touches[0].pageX;
              scrollLeft = wrapper.scrollLeft;
            }, {passive: true});

            wrapper.addEventListener('touchmove', (e) => {
              const x = e.touches[0].pageX;
              const walk = (touchStartX - x);
              wrapper.scrollLeft = scrollLeft + walk;
            }, {passive: true});

            // 替换原来的 pre 标签
            block.parentElement.replaceWith(wrapper);
          }
        });

        console.log(`总共找到 ${mermaidCount} 个 Mermaid 代码块`);

        // 运行 Mermaid 渲染
        if (mermaidCount > 0) {
          console.log('开始渲染 Mermaid 图表...');
          mermaid.run().then(() => {
            console.log('Mermaid 渲染完成!');
          }).catch(err => {
            console.error('Mermaid 渲染出错:', err);
          });
        }
      });
    </script>
  </body>
</html>
