---
interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <style>
      :root {
        --bg: #0d1117;
        --text: #e6edf3;
        --accent: #58a6ff;
        --accent-hover: #1f6feb;
        --gray: #8b949e;
        --border: #30363d;
        --code-bg: #161b22;
        --glow: 0 0 10px rgba(88, 166, 255, 0.3);
        --surface: #161b22;
      }

      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      body {
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif;
        background: var(--bg);
        background-image:
          linear-gradient(rgba(255, 255, 255, 0.02) 1px, transparent 1px),
          linear-gradient(90deg, rgba(255, 255, 255, 0.02) 1px, transparent 1px);
        background-size: 40px 40px;
        color: var(--text);
        line-height: 1.6;
        font-size: 16px;
      }

      main {
        max-width: 1000px;
        margin: 0 auto;
        padding: 2rem 2rem;
      }

      header {
        border-bottom: 1px solid var(--border);
        padding-bottom: 1rem;
        margin-bottom: 3rem;
      }

      nav {
        display: flex;
        gap: 2rem;
      }

      nav a {
        color: var(--accent);
        text-decoration: none;
        margin-right: 1.5rem;
        font-weight: 500;
        transition: all 0.3s;
      }

      nav a:hover {
        color: var(--accent-hover);
        text-shadow: var(--glow);
      }

      footer {
        border-top: 1px solid var(--border);
        margin-top: 4rem;
        padding-top: 1.5rem;
        color: var(--gray);
        font-size: 0.875rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
      }

      footer a {
        color: var(--accent);
        text-decoration: none;
      }

      footer a:hover {
        text-shadow: var(--glow);
      }
    </style>
  </head>
  <body>
    <main>
      <header>
        <nav>
          <a href="/">首页</a>
          <a href="/blog">博客</a>
          <a href="https://github.com/ink-hz" target="_blank">GitHub</a>
        </nav>
      </header>
      <slot />
      <footer>
        <span>© 2026 ink-hz · AI & 云原生技术</span>
        <span>
          <a href="mailto:ink_hz@163.com">ink_hz@163.com</a>
          &nbsp;·&nbsp;
          <a href="https://github.com/ink-hz" target="_blank">GitHub</a>
        </span>
      </footer>
    </main>

    <!-- Mermaid.js 客户端渲染 -->
    <script type="module">
      import mermaid from 'https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.esm.min.mjs';

      // 初始化 Mermaid - 使用 default 主题以支持内联 style
      mermaid.initialize({
        startOnLoad: false,
        theme: 'dark',  // dark 主题适配暗色背景
        flowchart: {
          useMaxWidth: true,
          htmlLabels: true,
          curve: 'basis'
        },
        securityLevel: 'loose'  // 允许自定义样式
      });

      // 等待 DOM 加载完成
      window.addEventListener('DOMContentLoaded', () => {
        console.log('开始查找 Mermaid 代码块...');

        // 查找所有可能包含 mermaid 的代码块
        const codeBlocks = document.querySelectorAll('pre code');
        console.log('找到代码块数量:', codeBlocks.length);

        let mermaidCount = 0;
        codeBlocks.forEach((block, index) => {
          // 检查是否是 mermaid 代码块（通过 class 或内容）
          const isMermaid = block.className.includes('mermaid') ||
                           block.className.includes('language-mermaid') ||
                           block.textContent.trim().startsWith('graph') ||
                           block.textContent.trim().startsWith('sequenceDiagram') ||
                           block.textContent.trim().startsWith('classDiagram') ||
                           block.textContent.trim().startsWith('flowchart');

          if (isMermaid) {
            mermaidCount++;
            console.log(`找到 Mermaid 代码块 #${mermaidCount}:`, block.className);

            // 获取 Mermaid 代码
            const code = block.textContent;

            // 创建一个新的 div 元素来渲染图表
            const mermaidDiv = document.createElement('div');
            mermaidDiv.className = 'mermaid';
            mermaidDiv.textContent = code;
            mermaidDiv.style.backgroundColor = '#161b22';
            mermaidDiv.style.padding = '20px';
            mermaidDiv.style.borderRadius = '8px';
            mermaidDiv.style.margin = '20px 0';

            // 替换原来的 pre 标签
            block.parentElement.replaceWith(mermaidDiv);
          }
        });

        console.log(`总共找到 ${mermaidCount} 个 Mermaid 代码块`);

        // 运行 Mermaid 渲染
        if (mermaidCount > 0) {
          console.log('开始渲染 Mermaid 图表...');
          mermaid.run().then(() => {
            console.log('Mermaid 渲染完成!');
          }).catch(err => {
            console.error('Mermaid 渲染出错:', err);
          });
        }
      });
    </script>
  </body>
</html>
